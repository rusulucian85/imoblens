generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlserver"
}

// ─── NextAuth ────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users ───────────────────────────────────────────────────────────────────

// role: VISITOR | BUYER | BUYER_PRO | AGENT | AGENT_PRO | ADMIN
// (SQL Server + Prisma 7 doesn't support enums; values enforced in app code)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  role          String    @default("BUYER")
  bannedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  agentProfile      AgentProfile?
  buyerProfile      BuyerProfile?
  subscription      Subscription?
  ownedListings     Listing[]          @relation("ListingOwner")
  reportedTxns      Transaction[]      @relation("TransactionReporter")
  favorites         Favorite[]
  savedSearches     SavedSearch[]
  listingViews      ListingView[]
  viewingsAsVisitor Viewing[]          @relation("ViewingVisitor")
  pushSubscriptions PushSubscription[]
  auditLogs         AuditLog[]
}

// ─── Agency ──────────────────────────────────────────────────────────────────

model Agency {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  website     String?
  email       String?
  phone       String?
  address     String?
  city        String?
  description String?
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agents   AgentProfile[]
  listings Listing[]
}

// ─── Agent ───────────────────────────────────────────────────────────────────

model AgentProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  agencyId    String?
  bio         String?
  licenseNo   String?
  yearsExp    Int?
  specialties String?  @default("[]")
  rating      Float?
  reviewCount Int      @default(0)
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  agency   Agency?   @relation(fields: [agencyId], references: [id])
  listings Listing[]
  viewings Viewing[] @relation("ViewingAgent")
}

// ─── Listing ─────────────────────────────────────────────────────────────────

// type:            APARTMENT | HOUSE | STUDIO | VILLA | LAND | COMMERCIAL | GARAGE
// status:          ACTIVE | PENDING | SOLD | RENTED | WITHDRAWN | RESERVED
// transactionType: SALE | RENT
model Listing {
  id              String    @id @default(cuid())
  slug            String    @unique
  agentId         String
  agencyId        String?
  ownerId         String?
  title           String
  description     String?
  descriptionEn   String?
  type            String
  status          String    @default("ACTIVE")
  transactionType String

  // Price
  priceAsked  Int
  pricePerSqm Int?
  currency    String @default("EUR")

  // Property details
  sqm          Float
  sqmLand      Float?
  rooms        Int?
  bathrooms    Int?
  floor        Int?
  totalFloors  Int?
  yearBuilt    Int?

  // Features
  hasParking Boolean @default(false)
  hasGarage  Boolean @default(false)
  hasBalcony Boolean @default(false)
  hasStorage Boolean @default(false)
  furnished  Boolean @default(false)

  // Location
  address      String
  city         String
  zone         String?
  county       String?
  postalCode   String?
  lat          Float
  lng          Float

  features    String? @default("[]")
  energyClass String?

  // Meta
  daysOnMarket Int?
  viewCount    Int     @default(0)
  featured     Boolean @default(false)
  publishedAt  DateTime?
  soldAt       DateTime?

  // moderationStatus: APPROVED | PENDING | REJECTED
  // (defaults APPROVED; admin queue activated when moderation feature ships)
  moderationStatus String @default("APPROVED")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations — NoAction on owner/agent/agency to avoid SQL Server multi-path
  // cascade conflicts (User reaches Listing through several routes)
  agent        AgentProfile   @relation(fields: [agentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  agency       Agency?        @relation(fields: [agencyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  owner        User?          @relation("ListingOwner", fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  images       ListingImage[]
  favorites    Favorite[]
  viewings     Viewing[]
  transactions Transaction[]
  views        ListingView[]

  @@index([city])
  @@index([status])
  @@index([transactionType])
  @@index([priceAsked])
  @@index([lat, lng])
  @@index([publishedAt])
}

model ListingImage {
  id        String   @id @default(cuid())
  listingId String
  url       String
  alt       String?
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

// ─── Transactions (the moat) ─────────────────────────────────────────────────

// Real, self-reported transaction prices. The owner of a Listing reports the
// actual sold price after the deal closes. One Listing can have many
// Transactions over its lifetime (sold 2018, resold 2024).
//
// source:        SELF_REPORTED | ANCPI | ADMIN_VERIFIED
// financeType:   CASH | MORTGAGE | MIXED
// buyerPurpose:  PRIMARY_RESIDENCE | INVESTMENT | VACATION | RENTAL
// buyerAge:      AGE_18_30 | AGE_30_45 | AGE_45_60 | AGE_60_PLUS
model Transaction {
  id           String  @id @default(cuid())
  listingId    String
  reportedById String
  priceAsked   Int
  priceSold    Int
  currency     String  @default("EUR")
  source       String  @default("SELF_REPORTED")
  verified     Boolean @default(false)

  // Anonymized buyer demographics (transparency for BUYER_PRO)
  financeType   String?
  buyerAge      String?
  buyerPurpose  String?
  buyerOrigin   String?

  soldAt    DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing    Listing @relation(fields: [listingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reportedBy User    @relation("TransactionReporter", fields: [reportedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([listingId])
  @@index([soldAt])
}

// ─── Buyer Search Profile ────────────────────────────────────────────────────

// Search preferences stored per user (NOT per-listing demographics — those
// live on Transaction). Powers personalized alerts and saved searches.
model BuyerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  budget      Int?
  minRooms    Int?
  maxRooms    Int?
  minArea     Float?
  maxArea     Float?
  cities      String?  @default("[]")
  preferences String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Favorites & Shortlists ──────────────────────────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  listName  String   @default("default")
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([userId, listingId, listName])
  @@index([userId])
}

// ─── Viewings ────────────────────────────────────────────────────────────────

// status: PENDING | CONFIRMED | CANCELLED | COMPLETED
model Viewing {
  id          String   @id @default(cuid())
  listingId   String
  visitorId   String
  agentId     String
  scheduledAt DateTime
  status      String   @default("PENDING")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  listing Listing      @relation(fields: [listingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  visitor User         @relation("ViewingVisitor", fields: [visitorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  agent   AgentProfile @relation("ViewingAgent", fields: [agentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

// ─── Push Subscriptions ──────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Subscriptions (Stripe) ──────────────────────────────────────────────────

// One active subscription per user. Stripe is the source of truth — we mirror
// the relevant fields here for fast role/gating checks without round-tripping.
//
// plan:   BUYER_PRO | AGENT_PRO
// status: ACTIVE | TRIALING | PAST_DUE | CANCELED | UNPAID | INCOMPLETE
model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  plan                 String
  status               String
  stripeCustomerId     String?
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
}

// ─── Saved Searches ──────────────────────────────────────────────────────────

// User's saved filters for alerts. `filters` is a JSON blob validated by Zod
// in app code (matches the chatbot's filter schema in Phase 2).
//
// frequency: REALTIME | DAILY | WEEKLY
model SavedSearch {
  id         String    @id @default(cuid())
  userId     String
  name       String
  filters    String
  frequency  String    @default("DAILY")
  lastSentAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Listing Views (analytics) ───────────────────────────────────────────────

// Granular view tracking for agent analytics ("5 BUYER_PRO views this week").
// Anonymous views captured via ipHash (GDPR-safe — hashed, not stored raw).
model ListingView {
  id        String   @id @default(cuid())
  listingId String
  userId    String?
  ipHash    String?
  userAgent String?
  viewedAt  DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user    User?   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([listingId, viewedAt])
  @@index([userId])
}

// ─── Audit Log (GDPR) ────────────────────────────────────────────────────────

// Records sensitive actions for GDPR compliance and abuse investigation:
// data exports, deletions, role changes, owner verification, price reports.
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  metadata   String?  // JSON blob
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
