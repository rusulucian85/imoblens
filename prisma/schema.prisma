generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlserver"
}

// ─── NextAuth ────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users ───────────────────────────────────────────────────────────────────

// UserRole: BUYER | AGENT | ADMIN
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  role          String    @default("BUYER")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  agentProfile      AgentProfile?
  buyerProfile      BuyerProfile?
  favorites         Favorite[]
  viewingsAsVisitor Viewing[]         @relation("ViewingVisitor")
  pushSubscriptions PushSubscription[]
}

// ─── Agency ──────────────────────────────────────────────────────────────────

model Agency {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  website     String?
  phone       String?
  address     String?
  city        String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agents   AgentProfile[]
  listings Listing[]
}

// ─── Agent ───────────────────────────────────────────────────────────────────

model AgentProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  agencyId    String?
  bio         String?
  licenseNo   String?
  yearsExp    Int?
  specialties String?  @default("[]")
  rating      Float?
  reviewCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  agency   Agency?   @relation(fields: [agencyId], references: [id])
  listings Listing[]
  viewings Viewing[] @relation("ViewingAgent")
}

// ─── Listing ─────────────────────────────────────────────────────────────────

// type: APARTMENT | HOUSE | STUDIO | VILLA | LAND | COMMERCIAL
// status: ACTIVE | PENDING | SOLD | RENTED | WITHDRAWN
// transactionType: SALE | RENT
model Listing {
  id              String    @id @default(cuid())
  slug            String    @unique
  agentId         String
  agencyId        String?
  title           String
  description     String?
  type            String
  status          String    @default("ACTIVE")
  transactionType String
  price           Int
  pricePerSqm     Int?
  currency        String    @default("EUR")
  area            Float
  rooms           Int?
  bathrooms       Int?
  floor           Int?
  totalFloors     Int?
  yearBuilt       Int?
  parking         Boolean   @default(false)
  furnished       Boolean   @default(false)
  address         String
  city            String
  neighborhood    String?
  county          String?
  postalCode      String?
  latitude        Float
  longitude       Float
  features        String?   @default("[]")
  energyClass     String?
  viewCount       Int       @default(0)
  featured        Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  agent     AgentProfile   @relation(fields: [agentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  agency    Agency?        @relation(fields: [agencyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  images    ListingImage[]
  favorites Favorite[]
  viewings  Viewing[]
}

model ListingImage {
  id        String   @id @default(cuid())
  listingId String
  url       String
  alt       String?
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

// ─── Buyer Profile ───────────────────────────────────────────────────────────

model BuyerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  budget      Int?
  minRooms    Int?
  maxRooms    Int?
  minArea     Float?
  maxArea     Float?
  cities      String?  @default("[]")
  preferences String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Favorites ───────────────────────────────────────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([userId, listingId])
}

// ─── Viewings ────────────────────────────────────────────────────────────────

// status: PENDING | CONFIRMED | CANCELLED | COMPLETED
model Viewing {
  id          String   @id @default(cuid())
  listingId   String
  visitorId   String
  agentId     String
  scheduledAt DateTime
  status      String   @default("PENDING")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  listing Listing      @relation(fields: [listingId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  visitor User         @relation("ViewingVisitor", fields: [visitorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  agent   AgentProfile @relation("ViewingAgent", fields: [agentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

// ─── Push Subscriptions ──────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
