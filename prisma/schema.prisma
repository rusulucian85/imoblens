generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth ────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users ───────────────────────────────────────────────────────────────────

enum UserRole {
  BUYER
  AGENT
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  role          UserRole  @default(BUYER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  agentProfile      AgentProfile?
  buyerProfile      BuyerProfile?
  favorites         Favorite[]
  viewingsAsVisitor Viewing[]         @relation("ViewingVisitor")
  pushSubscriptions PushSubscription[]
}

// ─── Agency ──────────────────────────────────────────────────────────────────

model Agency {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  website     String?
  phone       String?
  address     String?
  city        String?
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agents   AgentProfile[]
  listings Listing[]
}

// ─── Agent ───────────────────────────────────────────────────────────────────

model AgentProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  agencyId    String?
  bio         String?  @db.Text
  licenseNo   String?
  yearsExp    Int?
  specialties String[]
  rating      Float?
  reviewCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  agency   Agency?   @relation(fields: [agencyId], references: [id])
  listings Listing[]
  viewings Viewing[] @relation("ViewingAgent")
}

// ─── Listing ─────────────────────────────────────────────────────────────────

enum ListingType {
  APARTMENT
  HOUSE
  STUDIO
  VILLA
  LAND
  COMMERCIAL
}

enum ListingStatus {
  ACTIVE
  PENDING
  SOLD
  RENTED
  WITHDRAWN
}

enum TransactionType {
  SALE
  RENT
}

model Listing {
  id              String          @id @default(cuid())
  slug            String          @unique
  agentId         String
  agencyId        String?
  title           String
  description     String?         @db.Text
  type            ListingType
  status          ListingStatus   @default(ACTIVE)
  transactionType TransactionType
  price           Int
  pricePerSqm     Int?
  currency        String          @default("EUR")
  area            Float
  rooms           Int?
  bathrooms       Int?
  floor           Int?
  totalFloors     Int?
  yearBuilt       Int?
  parking         Boolean         @default(false)
  furnished       Boolean         @default(false)
  address         String
  city            String
  neighborhood    String?
  county          String?
  postalCode      String?
  latitude        Float
  longitude       Float
  features        String[]
  energyClass     String?
  viewCount       Int             @default(0)
  featured        Boolean         @default(false)
  publishedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  agent     AgentProfile   @relation(fields: [agentId], references: [id])
  agency    Agency?        @relation(fields: [agencyId], references: [id])
  images    ListingImage[]
  favorites Favorite[]
  viewings  Viewing[]
}

model ListingImage {
  id        String   @id @default(cuid())
  listingId String
  url       String
  alt       String?
  isPrimary Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

// ─── Buyer Profile ───────────────────────────────────────────────────────────

model BuyerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  budget      Int?
  minRooms    Int?
  maxRooms    Int?
  minArea     Float?
  maxArea     Float?
  cities      String[]
  preferences Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Favorites ───────────────────────────────────────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
}

// ─── Viewings ────────────────────────────────────────────────────────────────

enum ViewingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Viewing {
  id          String        @id @default(cuid())
  listingId   String
  visitorId   String
  agentId     String
  scheduledAt DateTime
  status      ViewingStatus @default(PENDING)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  listing Listing      @relation(fields: [listingId], references: [id])
  visitor User         @relation("ViewingVisitor", fields: [visitorId], references: [id])
  agent   AgentProfile @relation("ViewingAgent", fields: [agentId], references: [id])
}

// ─── Push Subscriptions ──────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
